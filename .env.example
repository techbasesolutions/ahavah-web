# Ahavah PWA — environment variables
# Copy to `.env.local` and fill in real values for local dev (or use defaults).
# Vercel sets production values via dashboard env vars.

# Backend REST base URL. Defaults to localhost:5000 (docker-compose api).
# Production: https://api.ahavah.app
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# Backend chat WebSocket URL. Defaults to ws://localhost:5443 (docker-compose chat).
# Production: wss://chat.ahavah.app:5443
NEXT_PUBLIC_CHAT_WS_URL=ws://localhost:5443
